{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://irion.example/schemas/duckdb-extension-qa-manifest-v1.json",
  "title": "Irion DuckDB Extension QA Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "duckdb",
    "extensions",
    "adapters"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "duckdb": {
      "$ref": "#/$defs/duckdbTarget"
    },
    "extensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/extension"
      }
    },
    "adapters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/adapter"
      }
    }
  },
  "$defs": {
    "gitSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "duckdbTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "ci_tools",
        "build"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "ci_tools": {
          "$ref": "#/$defs/gitSource"
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "platform",
            "runner",
            "build_type",
            "targets"
          ],
          "properties": {
            "platform": {
              "const": "linux_amd64"
            },
            "runner": {
              "const": "ubuntu-24.04"
            },
            "build_type": {
              "const": "Release"
            },
            "targets": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "duckdb",
                  "unittest"
                ]
              },
              "allOf": [
                {
                  "contains": {
                    "const": "duckdb"
                  }
                },
                {
                  "contains": {
                    "const": "unittest"
                  }
                }
              ]
            },
            "cmake_options": {
              "type": "object",
              "propertyNames": {
                "not": {
                  "pattern": "(?i)(extension|source_dir|load_tests)"
                }
              },
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean"
                ]
              }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binary_source",
        "install_statements",
        "load_statements"
      ],
      "properties": {
        "binary_source": {
          "enum": [
            "official_duckdb_repository",
            "approved_custom_repository"
          ]
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "install_statements": {
          "$ref": "#/$defs/sqlStatements"
        },
        "load_statements": {
          "$ref": "#/$defs/sqlStatements"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "binary_source": {
                "const": "approved_custom_repository"
              }
            }
          },
          "then": {
            "required": [
              "repository"
            ]
          }
        }
      ]
    },
    "sqlStatements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "not": {
          "pattern": "(?i)(cmake|make|ninja|source_dir)"
        }
      }
    },
    "testSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        }
      }
    },
    "extension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "enabled",
        "runtime",
        "test_source",
        "test_groups"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "enabled": {
          "type": "boolean"
        },
        "runtime": {
          "$ref": "#/$defs/runtime"
        },
        "test_source": {
          "$ref": "#/$defs/testSource"
        },
        "test_groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/testGroup"
          }
        }
      }
    },
    "testGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "runner",
        "test_dir",
        "include",
        "exclude",
        "include_slow",
        "timeout_seconds",
        "adapter",
        "minimum_executed_tests"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "runner": {
          "const": "duckdb_unittest"
        },
        "test_dir": {
          "type": "string",
          "minLength": 1
        },
        "include": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/exclusion"
          }
        },
        "include_slow": {
          "type": "boolean"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 60,
          "maximum": 14400
        },
        "adapter": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "minimum_executed_tests": {
          "type": "integer",
          "minimum": 1
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "exclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern",
        "category",
        "reason",
        "owner"
      ],
      "properties": {
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "enum": [
            "slow",
            "cloud_credentials",
            "unsupported_platform",
            "nondeterministic_external",
            "known_upstream_issue"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 10
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "expires": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation",
        "setup_timeout_seconds",
        "readiness_timeout_seconds",
        "teardown_timeout_seconds",
        "services"
      ],
      "properties": {
        "implementation": {
          "type": "string",
          "pattern": "^scripts/qa/adapters/"
        },
        "setup_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "readiness_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "teardown_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "required_host_capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "setup_tools": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/setupTool"
          }
        },
        "services": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/service"
          }
        }
      }
    },
    "setupTool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "purpose",
        "scope",
        "install_statements",
        "load_statements"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "purpose": {
          "type": "string",
          "minLength": 10
        },
        "scope": {
          "const": "adapter_setup_only"
        },
        "install_statements": {
          "$ref": "#/$defs/sqlStatements"
        },
        "load_statements": {
          "$ref": "#/$defs/sqlStatements"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "healthcheck",
        "log_paths"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "kind": {
          "enum": [
            "process",
            "container_stack"
          ]
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "ports": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          }
        },
        "healthcheck": {
          "$ref": "#/$defs/healthcheck"
        },
        "log_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "healthcheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "target",
        "interval_seconds",
        "timeout_seconds",
        "attempts"
      ],
      "properties": {
        "type": {
          "enum": [
            "tcp",
            "http",
            "command",
            "container_log"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        }
      }
    }
  }
}
